      "required": true
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": "Изучаем бизнес-цели, целевую аудиторию и технические требования. Формируем детальную дорожную карту проекта с понятными этапами и результатами.",
      "required": true
    },
    "testimonials": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.text",
      "repeatable": true,
      "required": true
    },
    "duration": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": "1-2 недели",
      "required": true
    },
    "image": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.media",
      "repeatable": false
    }
