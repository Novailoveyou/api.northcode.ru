      "default": "ERP для производственной компании",
      "required": true
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": "Заменили 5 разрозненных систем единой ERP. Сократили время обработки заказов на 60%. Руководитель видит всю картину в реальном времени.",
      "required": true
    },
    "image": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.media",
      "repeatable": false,
      "required": true
    },
    "link": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.link",
      "repeatable": false,
      "required": true
    },
    "images": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.media",
      "repeatable": true,
      "required": true
    }
  }
